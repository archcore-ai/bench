# Cloned repos (fetched at run time)
repos/

# Generated KB and arm builds (regenerated by gen_kb.py / build_arm.py)
scale/kb/
scale/arms/

# Run output caches
runs/

# Per-run JSON outputs (large, regenerated by running the benchmarks)
results/raw/
scale/results/raw/
scale/results/raw_plugin/
scale/results/*.log
scale/results/*.bak

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Claude Code local overrides (machine-specific paths/permissions)
.claude/settings.local.json

# Secrets / local config
.env
*.env
